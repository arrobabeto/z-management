# === Vercel (Project Settings → Environment Variables: Production + Preview) ===
# ORBITYPE_MOCK=false
# ORBITYPE_API_SQL_URL="https://core.orbitype.com/api/sql/v1"
# ORBITYPE_API_SQL_KEY="your-api-key"
# NUXT_PUBLIC_SITE_URL="https://your-project.vercel.app"
# (use your Vercel deployment URL — not localhost)
# NUXT_PUBLIC_SITE_NAME="Z-Management"
# NUXT_PUBLIC_SITE_DESCRIPTION="Lieferantenrisiken jederzeit im Griff"
# NUXT_PUBLIC_ORGANIZATION_NAME="Z-Management"
# NUXT_PUBLIC_OG_IMAGE_ENABLED="true"
# Node version: set to 20.x in Vercel Project Settings → General (see .nvmrc)

ORBITYPE_MOCK=true

# Optional Orbitype keys (local dev / MCP):
# ORBITYPE_API_SQL_KEY_MARKETING="your-marketing-sql-api-key"
# ORBITYPE_API_S3_URL="https://core.orbitype.com/api/s3/v1"
# ORBITYPE_API_S3_KEY="your-s3-api-key"

# Cursor MCP env vars (export in ~/.zshrc — see docs/orbitype-cms-mcp.md):
# ORBITYPE_SQL_API_KEY_PROD_WEBSITE="your-sql-api-key"
# ORBITYPE_SQL_API_KEY_PROD_MARKETING="your-marketing-sql-api-key"
# ORBITYPE_S3_PUBLIC_API_KEY_PROD="your-s3-api-key"

# Public SEO / branding settings (set NUXT_PUBLIC_SITE_URL to your Vercel URL in production):
NUXT_PUBLIC_SITE_URL="http://localhost:3000"
NUXT_PUBLIC_SITE_NAME="Z-Management"
NUXT_PUBLIC_SITE_DESCRIPTION="Lieferantenrisiken jederzeit im Griff"
NUXT_PUBLIC_ORGANIZATION_NAME="Z-Management"
NUXT_PUBLIC_ORGANIZATION_LOGO="/favicon.svg"
NUXT_PUBLIC_SITE_LOCALE="de_DE"
NUXT_PUBLIC_TWITTER_SITE="@orbitype"
NUXT_PUBLIC_TWITTER_CREATOR="@orbitype"
NUXT_PUBLIC_OG_IMAGE_ENABLED="true"
NUXT_PUBLIC_COMMENTS_ENABLED="false"
NUXT_PUBLIC_OG_LOGO_PATH="/favicon.svg"
# Optional GTM container (empty disables GTM script injection):
NUXT_PUBLIC_GTM_ID=""
